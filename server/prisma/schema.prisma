generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                @id @default(cuid())
  username               String                @unique
  email                  String                @unique
  passwordHash           String?
  discordId              String?               @unique
  rsiHandle              String?
  avatarUrl              String?
  bio                    String?
  role                   Role                  @default(REGISTERED)
  createdAt              DateTime              @default(now())
  updatedAt              DateTime              @updatedAt
  isAdmin                Boolean               @default(false)
  isSuperAdmin           Boolean               @default(false)
  publicProfile          Boolean               @default(false)
  accounts               Account[]
  activities             Activity[]
  comments               Comment[]
  eventRSVPs             EventRSVP[]
  createdEvents          Event[]               @relation("createdEvents")
  fleetShips             FleetShip[]           @relation("fleetShips")
  friendRequestsReceived Friendship[]          @relation("friendRequestsReceived")
  friendRequestsSent     Friendship[]          @relation("friendRequestsSent")
  groupMemberships       GroupMember[]
  ownedGroups            Group[]               @relation("ownedGroups")
  joinRequests           JoinRequest[]
  createdOperations      Operation[]           @relation("createdOperations")
  authoredAnnouncements  OrgAnnouncement[]     @relation("authoredAnnouncements")
  authoredGuides         OrgGuide[]            @relation("authoredGuides")
  orgMemberships         OrgMember[]
  ownedOrgs              Org[]                 @relation("ownedOrgs")
  reports                Report[]              @relation("reportAuthor")
  suggestionVotes        SuggestionVote[]
  suggestions            Suggestion[]          @relation("suggestionAuthor")
  treasuryTransactions   TreasuryTransaction[] @relation("treasuryTransactions")
  inventoryNotes         InventoryNote[]
  wikeloProjects         WikeloProject[]
  ownedWikeloGroups      WikeloGroup[]            @relation("ownedWikeloGroups")
  wikeloGroupMemberships WikeloGroupMember[]
  wikeloContributions    WikeloContributionLog[]
  refinerySubmissions    RefinerySubmission[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  provider          String
  providerAccountId String
  accessToken       String?
  refreshToken      String?
  expiresAt         Int?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Friendship {
  id          String       @id @default(cuid())
  requesterId String
  addresseeId String
  status      FriendStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  addressee   User         @relation("friendRequestsReceived", fields: [addresseeId], references: [id], onDelete: Cascade)
  requester   User         @relation("friendRequestsSent", fields: [requesterId], references: [id], onDelete: Cascade)

  @@unique([requesterId, addresseeId])
  @@map("friendships")
}

model Group {
  id          String        @id @default(cuid())
  name        String
  description String?
  ownerId     String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  events      Event[]
  members     GroupMember[]
  owner       User          @relation("ownedGroups", fields: [ownerId], references: [id], onDelete: Cascade)

  @@map("groups")
}

model GroupMember {
  id       String    @id @default(cuid())
  groupId  String
  userId   String
  role     GroupRole @default(MEMBER)
  joinedAt DateTime  @default(now())
  group    Group     @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("group_members")
}

model Event {
  id          String      @id @default(cuid())
  groupId     String?
  creatorId   String
  title       String
  description String?
  eventType   String
  startsAt    DateTime
  endsAt      DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  orgId       String?
  attendees   EventRSVP[]
  creator     User        @relation("createdEvents", fields: [creatorId], references: [id], onDelete: Cascade)
  group       Group?      @relation(fields: [groupId], references: [id], onDelete: Cascade)
  org         Org?        @relation("orgEvents", fields: [orgId], references: [id], onDelete: Cascade)

  @@map("events")
}

model EventRSVP {
  id      String     @id @default(cuid())
  eventId String
  userId  String
  status  RSVPStatus @default(GOING)
  event   Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_rsvps")
}

model Activity {
  id        String   @id @default(cuid())
  userId    String
  type      String
  targetId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  orgId     String?
  org       Org?     @relation("orgActivities", fields: [orgId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([orgId, createdAt])
  @@map("activities")
}

model Comment {
  id        String   @id @default(cuid())
  userId    String
  guidePath String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([guidePath, createdAt])
  @@map("comments")
}

model Org {
  id               String                @id @default(cuid())
  name             String                @unique
  slug             String                @unique
  description      String?
  spectrumId       String?
  logoUrl          String?
  bannerUrl        String?
  isPublic         Boolean               @default(true)
  ownerId          String
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt
  motd             String?
  orgActivities    Activity[]            @relation("orgActivities")
  orgEvents        Event[]               @relation("orgEvents")
  fleetShips       FleetShip[]
  joinRequests     JoinRequest[]
  operations       Operation[]
  announcements    OrgAnnouncement[]
  guides           OrgGuide[]
  members          OrgMember[]
  roles            OrgRole[]
  owner            User                  @relation("ownedOrgs", fields: [ownerId], references: [id], onDelete: Cascade)
  recruitmentPosts RecruitmentPost[]
  transactions     TreasuryTransaction[]

  @@map("orgs")
}

model OrgMember {
  id              String           @id @default(cuid())
  orgId           String
  userId          String
  roleId          String?
  joinedAt        DateTime         @default(now())
  crewAssignments CrewAssignment[]
  org             Org              @relation(fields: [orgId], references: [id], onDelete: Cascade)
  role            OrgRole?         @relation(fields: [roleId], references: [id])
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("org_members")
}

model OrgRole {
  id          String      @id @default(cuid())
  orgId       String
  name        String
  rank        Int         @default(0)
  permissions Json        @default("[]")
  createdAt   DateTime    @default(now())
  members     OrgMember[]
  org         Org         @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, name])
  @@map("org_roles")
}

model FleetShip {
  id             String          @id @default(cuid())
  orgId          String
  ownerId        String
  shipId         String
  shipName       String
  nickname       String?
  status         ShipStatus      @default(ACTIVE)
  createdAt      DateTime        @default(now())
  org            Org             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner          User            @relation("fleetShips", fields: [ownerId], references: [id], onDelete: Cascade)
  operationShips OperationShip[]

  @@map("fleet_ships")
}

model Operation {
  id            String          @id @default(cuid())
  orgId         String
  creatorId     String
  title         String
  description   String?
  operationType String
  status        OperationStatus @default(PLANNING)
  startsAt      DateTime?
  endsAt        DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  ships         OperationShip[]
  creator       User            @relation("createdOperations", fields: [creatorId], references: [id], onDelete: Cascade)
  org           Org             @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("operations")
}

model OperationShip {
  id              String           @id @default(cuid())
  operationId     String
  fleetShipId     String
  crewAssignments CrewAssignment[]
  fleetShip       FleetShip        @relation(fields: [fleetShipId], references: [id], onDelete: Cascade)
  operation       Operation        @relation(fields: [operationId], references: [id], onDelete: Cascade)

  @@unique([operationId, fleetShipId])
  @@map("operation_ships")
}

model CrewAssignment {
  id              String        @id @default(cuid())
  operationShipId String
  orgMemberId     String
  position        String
  seatId          String?
  notes           String?
  createdAt       DateTime      @default(now())
  operationShip   OperationShip @relation(fields: [operationShipId], references: [id], onDelete: Cascade)
  orgMember       OrgMember     @relation(fields: [orgMemberId], references: [id], onDelete: Cascade)

  @@unique([operationShipId, orgMemberId])
  @@index([operationShipId, seatId])
  @@map("crew_assignments")
}

model TreasuryTransaction {
  id          String          @id @default(cuid())
  orgId       String
  userId      String
  type        TransactionType
  amount      Int
  description String?
  createdAt   DateTime        @default(now())
  org         Org             @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user        User            @relation("treasuryTransactions", fields: [userId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@map("treasury_transactions")
}

model RecruitmentPost {
  id           String   @id @default(cuid())
  orgId        String
  title        String
  description  String
  requirements String?
  isOpen       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  org          Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("recruitment_posts")
}

model JoinRequest {
  id        String            @id @default(cuid())
  orgId     String
  userId    String
  message   String?
  status    JoinRequestStatus @default(PENDING)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  org       Org               @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("join_requests")
}

model OrgGuide {
  id        String        @id @default(cuid())
  orgId     String
  authorId  String
  title     String
  content   String
  category  GuideCategory @default(GENERAL)
  sortOrder Int           @default(0)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  author    User          @relation("authoredGuides", fields: [authorId], references: [id], onDelete: Cascade)
  org       Org           @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, category, sortOrder])
  @@map("org_guides")
}

model OrgAnnouncement {
  id        String   @id @default(cuid())
  orgId     String
  authorId  String
  title     String
  content   String
  isPinned  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  author    User     @relation("authoredAnnouncements", fields: [authorId], references: [id], onDelete: Cascade)
  org       Org      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@map("org_announcements")
}

model Report {
  id          String       @id @default(cuid())
  authorId    String
  type        ReportType
  status      ReportStatus @default(OPEN)
  title       String
  description String
  pageUrl     String?
  adminNotes  String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  author      User         @relation("reportAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@map("reports")
}

model Suggestion {
  id          String           @id @default(cuid())
  authorId    String
  title       String
  description String
  status      SuggestionStatus @default(PENDING)
  adminNotes  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  votes       SuggestionVote[]
  author      User             @relation("suggestionAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@map("suggestions")
}

model SuggestionVote {
  id           String     @id @default(cuid())
  suggestionId String
  userId       String
  createdAt    DateTime   @default(now())
  suggestion   Suggestion @relation(fields: [suggestionId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([suggestionId, userId])
  @@map("suggestion_votes")
}

model InventoryNote {
  id         String   @id @default(cuid())
  userId     String
  itemName   String
  totalCount Int      @default(0)
  sellCount  Int      @default(0)
  keepCount  Int      @default(0)
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("inventory_notes")
}

model CraftRecipe {
  id          String            @id @default(cuid())
  name        String
  description String?
  category    String
  outputItem  String
  outputQty   Int               @default(1)
  difficulty  String?
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  ingredients CraftIngredient[]

  @@index([category])
  @@map("craft_recipes")
}

model CraftIngredient {
  id       String      @id @default(cuid())
  recipeId String
  item     String
  quantity Int         @default(1)
  recipe   CraftRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@map("craft_ingredients")
}

model MissionRecipe {
  id           String             @id @default(cuid())
  name         String
  description  String?
  missionType  String
  difficulty   String?
  minPlayers   Int                @default(1)
  maxPlayers   Int?
  estimatedPay String?
  location     String?
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  objectives   MissionObjective[]
  rewards      MissionReward[]

  @@index([missionType])
  @@map("mission_recipes")
}

model MissionObjective {
  id          String        @id @default(cuid())
  missionId   String
  description String
  sortOrder   Int           @default(0)
  isOptional  Boolean       @default(false)
  mission     MissionRecipe @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@map("mission_objectives")
}

model MissionReward {
  id          String        @id @default(cuid())
  missionId   String
  rewardType  String
  description String
  quantity    String?
  mission     MissionRecipe @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@map("mission_rewards")
}

model GameOre {
  id          String   @id @default(cuid())
  name        String   @unique
  abbrev      String   @unique
  type        OreType
  valuePerSCU Int
  instability Float
  resistance  Float
  description String
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("game_ores")
}

model GameMiningLaser {
  id                  String   @id @default(cuid())
  name                String   @unique
  size                Int
  price               Int
  optimumRange        Int
  maxRange            Int
  minPower            Int
  minPowerPct         Float
  maxPower            Int
  extractPower        Int
  moduleSlots         Int
  resistance          Float
  instability         Float
  optimalChargeRate   Float
  optimalChargeWindow Float
  inertMaterials      Float
  description         String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([size])
  @@map("game_mining_lasers")
}

model GameMiningModule {
  id                   String         @id @default(cuid())
  name                 String         @unique
  category             ModuleCategory
  price                Int
  duration             Int            @default(0)
  uses                 Int            @default(0)
  miningLaserPower     Float          @default(0)
  laserInstability     Float          @default(0)
  resistance           Float          @default(0)
  optimalChargeWindow  Float          @default(0)
  optimalChargeRate    Float          @default(0)
  overchargeRate       Float          @default(0)
  shatterDamage        Float          @default(0)
  extractionLaserPower Float          @default(0)
  inertMaterials       Float          @default(0)
  clusterModifier      Float          @default(0)
  description          String
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@index([category])
  @@map("game_mining_modules")
}

model GameMiningShip {
  id            String   @id @default(cuid())
  name          String   @unique
  manufacturer  String
  size          String
  cargoSCU      Float
  miningTurrets Int
  crewMin       Int
  crewMax       Int
  isVehicle     Boolean  @default(false)
  description   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("game_mining_ships")
}

model GameRockSignature {
  id        String   @id @default(cuid())
  name      String   @unique
  rarity    String   @default("common")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("game_rock_signatures")
}

model GameRefineryMethod {
  id              String   @id @default(cuid())
  name            String   @unique
  yieldMultiplier Float
  relativeTime    Int
  relativeCost    Int
  description     String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("game_refinery_methods")
}

model GameRefineryStation {
  id        String   @id @default(cuid())
  name      String   @unique
  location  String
  bonuses   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("game_refinery_stations")
}

model GameMiningLocation {
  id         String   @id @default(cuid())
  name       String   @unique
  type       String
  parentBody String
  gravity    String
  atmosphere Boolean
  danger     String
  ores       Json
  fpsOres    Json     @default("[]")
  notes      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("game_mining_locations")
}

model WikeloGroup {
  id         String              @id @default(cuid())
  name       String
  inviteCode String              @unique
  ownerId    String
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  owner      User                @relation("ownedWikeloGroups", fields: [ownerId], references: [id], onDelete: Cascade)
  members    WikeloGroupMember[]
  projects   WikeloProject[]

  @@index([ownerId])
  @@map("wikelo_groups")
}

model WikeloGroupMember {
  id       String      @id @default(cuid())
  groupId  String
  userId   String
  joinedAt DateTime    @default(now())
  group    WikeloGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@map("wikelo_group_members")
}

model WikeloProject {
  id            String                  @id @default(cuid())
  userId        String
  contractId    String
  name          String
  displayName   String?
  status        WikeloProjectStatus     @default(IN_PROGRESS)
  groupId       String?
  priority      Int                     @default(0)
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt
  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  group         WikeloGroup?            @relation(fields: [groupId], references: [id])
  materials     WikeloProjectMaterial[]
  contributions WikeloContributionLog[]

  @@index([userId, status])
  @@index([groupId, status])
  @@map("wikelo_projects")
}

model WikeloProjectMaterial {
  id        String        @id @default(cuid())
  projectId String
  itemName  String
  required  Int
  collected Int           @default(0)
  project   WikeloProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, itemName])
  @@map("wikelo_project_materials")
}

model WikeloContributionLog {
  id        String        @id @default(cuid())
  projectId String
  userId    String
  itemName  String
  delta     Int
  newTotal  Int
  createdAt DateTime      @default(now())
  project   WikeloProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([userId, createdAt])
  @@map("wikelo_contribution_log")
}

enum WikeloProjectStatus {
  IN_PROGRESS
  COMPLETED
  ABANDONED
}

model PriceCache {
  id        String   @id @default(cuid())
  cacheKey  String   @unique
  data      Json
  fetchedAt DateTime @default(now())
  expiresAt DateTime

  @@index([cacheKey, expiresAt])
  @@map("price_cache")
}

model GameDataOverride {
  id        String   @id @default(cuid())
  category  String
  itemKey   String
  overrides Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, itemKey])
  @@map("game_data_overrides")
}

enum JoinRequestStatus {
  PENDING
  APPROVED
  DENIED
}

enum Role {
  VISITOR
  REGISTERED
  GROUP_MEMBER
  ORG_MEMBER
  ORG_LEADER
  ADMIN
}

enum FriendStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum GroupRole {
  MEMBER
  OFFICER
  LEADER
}

enum RSVPStatus {
  GOING
  MAYBE
  NOT_GOING
}

enum ShipStatus {
  ACTIVE
  DESTROYED
  LOANED
  IN_REPAIR
}

enum OperationStatus {
  PLANNING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
}

enum GuideCategory {
  RANKS
  OPERATIONS
  TREASURY
  RULES
  GENERAL
}

enum ReportType {
  BUG
  DATA_ISSUE
}

enum ReportStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SuggestionStatus {
  PENDING
  UNDER_REVIEW
  PLANNED
  DECLINED
}

enum ModuleCategory {
  ACTIVE
  PASSIVE
  GADGET
}

enum OreType {
  ROCK
  GEM
  METAL
}

enum RefinerySubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

model RefinerySubmission {
  id          String                    @id @default(cuid())
  userId      String
  user        User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  stationName String
  oreName     String
  bonusPct    Int
  notes       String?
  status      RefinerySubmissionStatus  @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime                  @default(now())

  @@index([status])
  @@index([stationName, oreName])
  @@map("refinery_submissions")
}
